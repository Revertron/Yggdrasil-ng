ARG CROSS_BASE_IMAGE
FROM ${CROSS_BASE_IMAGE}

COPY contrib/cross/gcc-crt-wrapper.sh /usr/local/bin/gcc-crt-wrapper
RUN chmod +x /usr/local/bin/gcc-crt-wrapper

# Create empty libunwind stub — MIPS musl containers lack libunwind,
# but it's only needed for backtrace unwinding which isn't used with panic=abort.
RUN ar rcs $CROSS_MUSL_SYSROOT/lib/libunwind.a

ENV CARGO_TARGET_MIPS_UNKNOWN_LINUX_MUSL_LINKER=gcc-crt-wrapper \
    CARGO_TARGET_MIPSEL_UNKNOWN_LINUX_MUSL_LINKER=gcc-crt-wrapper \
    CARGO_TARGET_MIPS64_UNKNOWN_LINUX_MUSLABI64_LINKER=gcc-crt-wrapper \
    CARGO_TARGET_MIPS64EL_UNKNOWN_LINUX_MUSLABI64_LINKER=gcc-crt-wrapper
